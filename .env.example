# =========================
# Hosted Service / Docker
# =========================

# HTTP 服务监听端口。compose 默认会将宿主机同名端口映射到容器 3000。
PORT=3000

# 对外访问地址。OAuth 回调和魔法链接会用到它。
AUTH_BASE_URL=http://localhost:3000

# 官方托管模式的基础配置。
APP_NAME=omni-login-kit
AUTH_ROUTE_PREFIX=/auth
AUTH_JWT_SECRET=change-this-before-production
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=30d
AUTH_ISSUER=omni-login-kit
AUTH_AUDIENCE=omni-login-kit-users
AUTH_TRUSTED_REDIRECT_HOSTS=localhost:3000
AUTH_ENABLE_AUDIT_LOG=true
TRUST_PROXY=true

# =========================
# Database
# =========================

# 如果你直接用仓库自带 compose，默认值可以不改。
# 如果你接外部 PostgreSQL，请改成真实连接串。
DATABASE_URL=postgres://postgres:postgres@postgres:5432/omni_login_kit
POSTGRES_DB=omni_login_kit
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# =========================
# Password Provider
# =========================

# Docker 模式默认启用密码登录，保证服务能开箱即用。
AUTH_PASSWORD_ENABLED=true
AUTH_ALLOW_USERNAME=true
AUTH_ALLOW_EMAIL=true
AUTH_ALLOW_PHONE=true

# =========================
# Email Providers
# =========================

AUTH_EMAIL_CODE_ENABLED=false
AUTH_EMAIL_MAGIC_LINK_ENABLED=false
AUTH_EMAIL_CODE_LENGTH=6
AUTH_EMAIL_CODE_EXPIRES_IN_SECONDS=300
AUTH_EMAIL_MAGIC_LINK_EXPIRES_IN_SECONDS=900

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# =========================
# SMS Provider
# =========================

AUTH_SMS_ENABLED=false
AUTH_SMS_SENDER=tencent-sms
AUTH_SMS_CODE_LENGTH=6
AUTH_SMS_EXPIRES_IN_SECONDS=300

# 阿里云短信
ALIYUN_SMS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_SIGN=
ALIYUN_SMS_TEMPLATE=

# 腾讯云短信
TENCENT_SMS_SECRET_ID=
TENCENT_SMS_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou

# =========================
# OAuth Providers
# =========================

AUTH_WECHAT_ENABLED=false
AUTH_WECHAT_SCOPE=snsapi_login
WECHAT_CLIENT_ID=
WECHAT_CLIENT_SECRET=

AUTH_WECOM_ENABLED=false
AUTH_WECOM_SCOPE=snsapi_login
WECOM_CLIENT_ID=
WECOM_CLIENT_SECRET=

AUTH_FEISHU_ENABLED=false
AUTH_FEISHU_SCOPE=contact:user.base:readonly
FEISHU_CLIENT_ID=
FEISHU_CLIENT_SECRET=
